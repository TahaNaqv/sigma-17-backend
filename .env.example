# Example environment file for Sigma‑17 backend.
# Copy this to `.env` and modify values for your local or production
# environment. Do **not** check the real `.env` into source control.

# === Database settings ===
# Either supply the individual parameters below or set DATABASE_URL.
DB_NAME=sigma17
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# alternatively:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/sigma17

# === Django configuration ===
# Replace with a strong, unique secret key for each deployment.
SECRET_KEY=django-insecure-replace-this-with-your-own

# Set to False in production; True enables debug output.
DEBUG=True

# Hosts the app will serve.  Comma-separated.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# === CORS ===
# When DEBUG=False, whitelist the origins allowed to make requests.
CORS_ALLOW_ALL_ORIGINS=True  # change to False in production
CORS_ALLOWED_ORIGINS=
# e.g. https://sigma17.leadrisks.com,https://sigma17.netlify.app

# === Optional API configuration ===
# Used by the frontend to construct absolute URLs (if needed).
API_HOST=api.sigma17.leadrisks.com

# === Additional settings ===
# Any other environment variables that your code reads can be added here.
