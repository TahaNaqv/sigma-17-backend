# Database
DB_NAME=sigma17
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Or use a single DATABASE_URL instead:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sigma17

# Secret key
SECRET_KEY=your-secret-key-here

# Debug
DEBUG=True

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS Configuration
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://sigma17.leadrisks.com,https://www.sigma17.leadrisks.com,http://localhost:3000

# API Configuration
API_HOST=api.sigma17.leadrisks.com
